local UI = {}
UI.__index = UI

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "Imgui"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = PlayerGui

local CurrentWindow = nil
local LayoutY = 10

local function create(class, props)
    local obj = Instance.new(class)
    for i,v in pairs(props) do
        obj[i] = v
    end
    return obj
end

function UI:Begin(name)

    if CurrentWindow then
        CurrentWindow:Destroy()
    end

    LayoutY = 10

    local window = create("Frame",{
        Parent = ScreenGui,
        Size = UDim2.new(0,260,0,400),
        Position = UDim2.new(0,20,0,20),
        BackgroundColor3 = Color3.fromRGB(30,30,30),
        BorderSizePixel = 0
    })

    create("TextLabel",{
        Parent = window,
        Size = UDim2.new(1,0,0,30),
        BackgroundColor3 = Color3.fromRGB(20,20,20),
        Text = name,
        TextColor3 = Color3.new(1,1,1),
        Font = Enum.Font.Code,
        TextSize = 16
    })

    CurrentWindow = window
end

function UI:Label(text)

    local label = create("TextLabel",{
        Parent = CurrentWindow,
        Size = UDim2.new(1,-20,0,20),
        Position = UDim2.new(0,10,0,LayoutY),
        BackgroundTransparency = 1,
        Text = text,
        TextColor3 = Color3.new(1,1,1),
        Font = Enum.Font.Code,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    LayoutY += 25
end

function UI:Button(text, callback)

    local button = create("TextButton",{
        Parent = CurrentWindow,
        Size = UDim2.new(1,-20,0,25),
        Position = UDim2.new(0,10,0,LayoutY),
        BackgroundColor3 = Color3.fromRGB(45,45,45),
        Text = text,
        TextColor3 = Color3.new(1,1,1),
        Font = Enum.Font.Code,
        TextSize = 14
    })

    button.MouseButton1Click:Connect(function()
        if callback then callback() end
    end)

    LayoutY += 30
end

function UI:Checkbox(text, state, callback)

    local toggle = create("TextButton",{
        Parent = CurrentWindow,
        Size = UDim2.new(1,-20,0,25),
        Position = UDim2.new(0,10,0,LayoutY),
        BackgroundColor3 = Color3.fromRGB(45,45,45),
        Text = text.." : "..tostring(state),
        TextColor3 = Color3.new(1,1,1),
        Font = Enum.Font.Code,
        TextSize = 14
    })

    toggle.MouseButton1Click:Connect(function()
        state = not state
        toggle.Text = text.." : "..tostring(state)

        if callback then
            callback(state)
        end
    end)

    LayoutY += 30
end

function UI:Slider(text, min, max, value, callback)

    local frame = create("Frame",{
        Parent = CurrentWindow,
        Size = UDim2.new(1,-20,0,40),
        Position = UDim2.new(0,10,0,LayoutY),
        BackgroundTransparency = 1
    })

    local label = create("TextLabel",{
        Parent = frame,
        Size = UDim2.new(1,0,0,20),
        BackgroundTransparency = 1,
        Text = text.." : "..value,
        TextColor3 = Color3.new(1,1,1),
        Font = Enum.Font.Code,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left
    })

    local slider = create("Frame",{
        Parent = frame,
        Size = UDim2.new(1,0,0,10),
        Position = UDim2.new(0,0,0,25),
        BackgroundColor3 = Color3.fromRGB(50,50,50)
    })

    local fill = create("Frame",{
        Parent = slider,
        Size = UDim2.new((value-min)/(max-min),0,1,0),
        BackgroundColor3 = Color3.fromRGB(120,120,255),
        BorderSizePixel = 0
    })

    slider.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then

            local mouse = game:GetService("UserInputService"):GetMouseLocation()

            local percent = math.clamp(
                (mouse.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X,
                0,1
            )

            value = math.floor(min + (max-min)*percent)

            fill.Size = UDim2.new(percent,0,1,0)
            label.Text = text.." : "..value

            if callback then
                callback(value)
            end
        end
    end)

    LayoutY += 45
end

function UI:End()
    CurrentWindow = nil
end

return UI
